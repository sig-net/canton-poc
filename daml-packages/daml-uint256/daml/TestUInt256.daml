-- ---------------------------------------------------------------------------
-- 48. Frozen fuzz vectors (50 random pairs)
-- ---------------------------------------------------------------------------

testFrozenFuzz : Script ()
testFrozenFuzz = do
  assertMsg "fuzz0 add" (hexAddUint256 fuzz0a fuzz0b == fuzz0add)
  assertMsg "fuzz0 sub" (hexSubUint256 fuzz0a fuzz0b == fuzz0sub)
  assertMsg "fuzz0 mul" (hexMulUint256 fuzz0a fuzz0b == fuzz0mul)
  let (q0, r0) = uint256DivInt (uint256FromHex fuzz0a) fuzz0d
  assertMsg "fuzz0 divQ" (uint256ToHex q0 == fuzz0divQ)
  assertMsg "fuzz0 divR" (r0 == fuzz0divR)
  assertMsg "fuzz1 add" (hexAddUint256 fuzz1a fuzz1b == fuzz1add)
  assertMsg "fuzz1 sub" (hexSubUint256 fuzz1a fuzz1b == fuzz1sub)
  assertMsg "fuzz1 mul" (hexMulUint256 fuzz1a fuzz1b == fuzz1mul)
  let (q1, r1) = uint256DivInt (uint256FromHex fuzz1a) fuzz1d
  assertMsg "fuzz1 divQ" (uint256ToHex q1 == fuzz1divQ)
  assertMsg "fuzz1 divR" (r1 == fuzz1divR)
  assertMsg "fuzz2 add" (hexAddUint256 fuzz2a fuzz2b == fuzz2add)
  assertMsg "fuzz2 sub" (hexSubUint256 fuzz2a fuzz2b == fuzz2sub)
  assertMsg "fuzz2 mul" (hexMulUint256 fuzz2a fuzz2b == fuzz2mul)
  let (q2, r2) = uint256DivInt (uint256FromHex fuzz2a) fuzz2d
  assertMsg "fuzz2 divQ" (uint256ToHex q2 == fuzz2divQ)
  assertMsg "fuzz2 divR" (r2 == fuzz2divR)
  assertMsg "fuzz3 add" (hexAddUint256 fuzz3a fuzz3b == fuzz3add)
  assertMsg "fuzz3 sub" (hexSubUint256 fuzz3a fuzz3b == fuzz3sub)
  assertMsg "fuzz3 mul" (hexMulUint256 fuzz3a fuzz3b == fuzz3mul)
  let (q3, r3) = uint256DivInt (uint256FromHex fuzz3a) fuzz3d
  assertMsg "fuzz3 divQ" (uint256ToHex q3 == fuzz3divQ)
  assertMsg "fuzz3 divR" (r3 == fuzz3divR)
  assertMsg "fuzz4 add" (hexAddUint256 fuzz4a fuzz4b == fuzz4add)
  assertMsg "fuzz4 sub" (hexSubUint256 fuzz4a fuzz4b == fuzz4sub)
  assertMsg "fuzz4 mul" (hexMulUint256 fuzz4a fuzz4b == fuzz4mul)
  let (q4, r4) = uint256DivInt (uint256FromHex fuzz4a) fuzz4d
  assertMsg "fuzz4 divQ" (uint256ToHex q4 == fuzz4divQ)
  assertMsg "fuzz4 divR" (r4 == fuzz4divR)
  assertMsg "fuzz5 add" (hexAddUint256 fuzz5a fuzz5b == fuzz5add)
  assertMsg "fuzz5 sub" (hexSubUint256 fuzz5a fuzz5b == fuzz5sub)
  assertMsg "fuzz5 mul" (hexMulUint256 fuzz5a fuzz5b == fuzz5mul)
  let (q5, r5) = uint256DivInt (uint256FromHex fuzz5a) fuzz5d
  assertMsg "fuzz5 divQ" (uint256ToHex q5 == fuzz5divQ)
  assertMsg "fuzz5 divR" (r5 == fuzz5divR)
  assertMsg "fuzz6 add" (hexAddUint256 fuzz6a fuzz6b == fuzz6add)
  assertMsg "fuzz6 sub" (hexSubUint256 fuzz6a fuzz6b == fuzz6sub)
  assertMsg "fuzz6 mul" (hexMulUint256 fuzz6a fuzz6b == fuzz6mul)
  let (q6, r6) = uint256DivInt (uint256FromHex fuzz6a) fuzz6d
  assertMsg "fuzz6 divQ" (uint256ToHex q6 == fuzz6divQ)
  assertMsg "fuzz6 divR" (r6 == fuzz6divR)
  assertMsg "fuzz7 add" (hexAddUint256 fuzz7a fuzz7b == fuzz7add)
  assertMsg "fuzz7 sub" (hexSubUint256 fuzz7a fuzz7b == fuzz7sub)
  assertMsg "fuzz7 mul" (hexMulUint256 fuzz7a fuzz7b == fuzz7mul)
  let (q7, r7) = uint256DivInt (uint256FromHex fuzz7a) fuzz7d
  assertMsg "fuzz7 divQ" (uint256ToHex q7 == fuzz7divQ)
  assertMsg "fuzz7 divR" (r7 == fuzz7divR)
  assertMsg "fuzz8 add" (hexAddUint256 fuzz8a fuzz8b == fuzz8add)
  assertMsg "fuzz8 sub" (hexSubUint256 fuzz8a fuzz8b == fuzz8sub)
  assertMsg "fuzz8 mul" (hexMulUint256 fuzz8a fuzz8b == fuzz8mul)
  let (q8, r8) = uint256DivInt (uint256FromHex fuzz8a) fuzz8d
  assertMsg "fuzz8 divQ" (uint256ToHex q8 == fuzz8divQ)
  assertMsg "fuzz8 divR" (r8 == fuzz8divR)
  assertMsg "fuzz9 add" (hexAddUint256 fuzz9a fuzz9b == fuzz9add)
  assertMsg "fuzz9 sub" (hexSubUint256 fuzz9a fuzz9b == fuzz9sub)
  assertMsg "fuzz9 mul" (hexMulUint256 fuzz9a fuzz9b == fuzz9mul)
  let (q9, r9) = uint256DivInt (uint256FromHex fuzz9a) fuzz9d
  assertMsg "fuzz9 divQ" (uint256ToHex q9 == fuzz9divQ)
