    exerciseCmd vaultCid CompleteWithdrawal with
      requester = userB; pendingWithdrawalCid = pendingCid; respondBidirectionalEventCid; signatureRespondedEventCid

------------------------------------------------------------------------
-- Double-claim: second ClaimDeposit on archived PendingDeposit fails
------------------------------------------------------------------------

-- second ClaimDeposit on same PendingDeposit fails (contract archived after first claim)
testPendingDepositDoubleClaimFails : Script ()
testPendingDepositDoubleClaimFails = do
  (sigNetwork, operator, requester, _signerCid, vaultCid) <- setupWithKey claimTestPubKey

  pendingCid <- submit operator do
    createCmd PendingDeposit with
      operators = [operator]; requester; sigNetwork
      requestId = claimTestRequestId; evmTxParams = sampleEvmParams

  respondBidirectionalEventCid1 <- submit sigNetwork do
    createCmd RespondBidirectionalEvent with
      sigNetwork; operators = [operator]; requester
      requestId = claimTestRequestId
      responder = sigNetwork; serializedOutput = boolTrueMpcOutput
      signature = claimTestSignature

  signatureRespondedEventCid1 <- submit sigNetwork do
    createCmd SignatureRespondedEvent with
      sigNetwork; operators = [operator]; requester
      requestId = claimTestRequestId
      responder = sigNetwork; signature = claimTestSignature

  -- First claim succeeds
  _holdingCid <- submit (actAs requester <> readAs operator <> readAs sigNetwork) do
    exerciseCmd vaultCid ClaimDeposit with
      requester; pendingDepositCid = pendingCid; respondBidirectionalEventCid = respondBidirectionalEventCid1; signatureRespondedEventCid = signatureRespondedEventCid1

  -- Fresh evidence for the second attempt (first pair was archived)
  respondBidirectionalEventCid2 <- submit sigNetwork do
    createCmd RespondBidirectionalEvent with
      sigNetwork; operators = [operator]; requester
      requestId = claimTestRequestId
      responder = sigNetwork; serializedOutput = boolTrueMpcOutput
      signature = claimTestSignature

  signatureRespondedEventCid2 <- submit sigNetwork do
    createCmd SignatureRespondedEvent with
      sigNetwork; operators = [operator]; requester
      requestId = claimTestRequestId
      responder = sigNetwork; signature = claimTestSignature

  -- Second claim must fail — pendingCid was archived
  submitMustFail (actAs requester <> readAs operator <> readAs sigNetwork) do
    exerciseCmd vaultCid ClaimDeposit with
      requester; pendingDepositCid = pendingCid; respondBidirectionalEventCid = respondBidirectionalEventCid2; signatureRespondedEventCid = signatureRespondedEventCid2

  pure ()

------------------------------------------------------------------------
-- Auth card with remainingUses=1 is fully consumed after one deposit
------------------------------------------------------------------------

-- RequestDeposit with remainingUses=1 fully consumes auth card (no replacement created)
testAuthCardSingleUseFullyConsumed : Script ()
testAuthCardSingleUseFullyConsumed = do
  (sigNetwork, operator, requester, signerCid, vaultCid) <- setup
  authCid <- getAuth operator requester vaultCid 1

  _result <- submit (actAs requester <> readAs operator <> readAs sigNetwork) do
    exerciseCmd vaultCid RequestDeposit with
      requester; signerCid; path = partyToText requester; evmTxParams = sampleEvmParams
      authCid; nonceCidText = "test-nonce"
      keyVersion = 1; algo = "ECDSA"; dest = "ethereum"; params = ""
      outputDeserializationSchema = erc20BoolSchema
      respondSerializationSchema = erc20BoolSchema

  -- No authorization should remain for this requester
  auths <- queryFilter @Authorization operator (\a -> a.owner == requester)
  assertMsg "auth card must be fully consumed" (null auths)

------------------------------------------------------------------------
-- RequestWithdrawal rejects wrong function signature
------------------------------------------------------------------------

-- RequestWithdrawal rejects EVM call with function other than transfer(address,uint256)
testWithdrawalRejectsWrongFunctionSignature : Script ()
testWithdrawalRejectsWrongFunctionSignature = do
  (sigNetwork, operator, requester, signerCid, vaultCid) <- setup

  holdingCid <- submit operator do
    createCmd Erc20Holding with
      operators = [operator]; owner = requester
      erc20Address = sampleErc20Address; amount = sampleHoldingAmount

  let badParams = sampleWithdrawalEvmParams with functionSignature = "approve(address,uint256)"
  submitMustFail (actAs requester <> readAs operator <> readAs sigNetwork) do
    exerciseCmd vaultCid RequestWithdrawal with
      requester; signerCid; evmTxParams = badParams
      recipientAddress = sampleRecipientAddress; balanceCid = holdingCid
      nonceCidText = "holding-nonce"
      keyVersion = 1; algo = "ECDSA"; dest = "ethereum"; params = ""
      outputDeserializationSchema = erc20BoolSchema
      respondSerializationSchema = erc20BoolSchema

------------------------------------------------------------------------
-- RequestWithdrawal rejects holding with mismatched operators
------------------------------------------------------------------------

-- RequestWithdrawal rejects holding whose operators differ from Vault operators
testWithdrawalRejectsHoldingOperatorsMismatch : Script ()
testWithdrawalRejectsHoldingOperatorsMismatch = do
  (sigNetwork, operator, requester, signerCid, vaultCid) <- setup
  rogue <- allocateParty "Rogue"

  holdingCid <- submit rogue do
    createCmd Erc20Holding with
      operators = [rogue]; owner = requester
      erc20Address = sampleErc20Address; amount = sampleHoldingAmount

  submitMustFail (actAs requester <> readAs operator <> readAs sigNetwork <> readAs rogue) do
    exerciseCmd vaultCid RequestWithdrawal with
      requester; signerCid; evmTxParams = sampleWithdrawalEvmParams
      recipientAddress = sampleRecipientAddress; balanceCid = holdingCid
      nonceCidText = "holding-nonce"
      keyVersion = 1; algo = "ECDSA"; dest = "ethereum"; params = ""
      outputDeserializationSchema = erc20BoolSchema
      respondSerializationSchema = erc20BoolSchema

------------------------------------------------------------------------
-- CompleteWithdrawal rejects requestId mismatch
------------------------------------------------------------------------

-- CompleteWithdrawal rejects when outcome.requestId differs from pending.requestId
testCompleteWithdrawalRejectsRequestIdMismatch : Script ()
testCompleteWithdrawalRejectsRequestIdMismatch = do
  (sigNetwork, operator, requester, _signerCid, vaultCid) <- setupWithKey claimTestPubKey

  pendingCid <- submit operator do
    createCmd PendingWithdrawal with
      operators = [operator]; requester; sigNetwork
      requestId = "aa"; evmTxParams = sampleWithdrawalEvmParams
      erc20Address = sampleErc20Address; amount = sampleHoldingAmount

  respondBidirectionalEventCid <- submit sigNetwork do
    createCmd RespondBidirectionalEvent with
      sigNetwork; operators = [operator]; requester
      requestId = "bb"
      responder = sigNetwork; serializedOutput = boolTrueMpcOutput
      signature = claimTestSignature

  signatureRespondedEventCid <- submit sigNetwork do
    createCmd SignatureRespondedEvent with
      sigNetwork; operators = [operator]; requester
      requestId = "bb"
      responder = sigNetwork; signature = claimTestSignature

  submitMustFail (actAs requester <> readAs operator <> readAs sigNetwork) do
    exerciseCmd vaultCid CompleteWithdrawal with
      requester; pendingWithdrawalCid = pendingCid; respondBidirectionalEventCid; signatureRespondedEventCid

  pure ()

------------------------------------------------------------------------
-- CompleteWithdrawal with bool(false) MPC output returns refund
------------------------------------------------------------------------

-- CompleteWithdrawal with bool(false) MPC output returns Some (refund holding with correct fields)
testCompleteWithdrawalBoolFalseRefunds : Script ()
testCompleteWithdrawalBoolFalseRefunds = do
  (sigNetwork, operator, requester, _signerCid, vaultCid) <- setupWithKey claimTestPubKey

  pendingCid <- submit operator do
    createCmd PendingWithdrawal with
      operators = [operator]; requester; sigNetwork
      requestId = claimTestRequestId; evmTxParams = sampleWithdrawalEvmParams
      erc20Address = sampleErc20Address; amount = sampleHoldingAmount

  respondBidirectionalEventCid <- submit sigNetwork do
    createCmd RespondBidirectionalEvent with
      sigNetwork; operators = [operator]; requester
      requestId = claimTestRequestId
      responder = sigNetwork; serializedOutput = boolFalseMpcOutput
      signature = boolFalseTestSignature

  signatureRespondedEventCid <- submit sigNetwork do
    createCmd SignatureRespondedEvent with
      sigNetwork; operators = [operator]; requester
      requestId = claimTestRequestId
      responder = sigNetwork; signature = boolFalseTestSignature

  result <- submit (actAs requester <> readAs operator <> readAs sigNetwork) do
    exerciseCmd vaultCid CompleteWithdrawal with
      requester; pendingWithdrawalCid = pendingCid; respondBidirectionalEventCid; signatureRespondedEventCid

  assertMsg "bool(false) must return Some (refund)" (isSome result)
  let refundCid = fromSome result
  refund <- queryContractId requester refundCid
  let h = fromSome refund
  assertMsg "refund owner" (h.owner == requester)
  assertMsg "refund operators" (h.operators == [operator])
  assertMsg "refund erc20Address" (h.erc20Address == sampleErc20Address)
  assertMsg "refund amount" (h.amount == sampleHoldingAmount)
