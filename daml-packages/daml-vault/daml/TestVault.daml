module TestVault where

import DA.Optional (fromSome, isSome, isNone)
import DA.List (head)
import DA.Crypto.Text (byteCount)
import Daml.Script

import Signer
import Erc20Vault
import TestFixtures
  ( testPubKeyHex, claimTestPubKey, claimTestSignature, claimTestRequestId
  , refundTestSignature, boolFalseTestSignature
  , sampleVaultAddress, sampleEvmParams, sampleWithdrawalEvmParams
  , sampleRecipientAddress, sampleErc20Address, sampleHoldingAmount
  , erc20BoolSchema, boolTrueMpcOutput, boolFalseMpcOutput, errorPrefixMpcOutput
  )

------------------------------------------------------------------------
-- Helpers
------------------------------------------------------------------------

-- Standard three-party setup returning (signerCid, vaultCid)
setup : Script (Party, Party, Party, ContractId Signer, ContractId Vault)
setup = setupWithKey testPubKeyHex

setupWithKey : Text -> Script (Party, Party, Party, ContractId Signer, ContractId Vault)
setupWithKey pubKey = do
  sigNetwork <- allocateParty "SigNetwork"
  operator   <- allocateParty "Operator"
  requester     <- allocateParty "Sender"

  signerCid <- submit sigNetwork do
    createCmd Signer with sigNetwork

  vaultCid <- submit operator do
    createCmd Vault with
      operators = [operator]; sigNetwork
      evmVaultAddress = sampleVaultAddress
      evmMpcPublicKey = pubKey
      vaultId = "test-vault"

  pure (sigNetwork, operator, requester, signerCid, vaultCid)

-- Obtain an Authorization with `n` remaining uses
getAuth : Party -> Party -> ContractId Vault -> Int -> Script (ContractId Authorization)
getAuth operator requester vaultCid n = do
  requestCid <- submit (actAs requester <> readAs operator) do
    exerciseCmd vaultCid RequestAuthorization with requester
  submit operator do
    exerciseCmd vaultCid ApproveAuthorization with requestCid; remainingUses = n; approver = operator

------------------------------------------------------------------------
-- Deposit lifecycle
------------------------------------------------------------------------

-- RequestDeposit creates SignBidirectionalEvent + PendingDeposit with correct requestId and evmTxParams
testDepositLifecycle : Script ()
testDepositLifecycle = do
  (sigNetwork, operator, requester, signerCid, vaultCid) <- setup
  authCid <- getAuth operator requester vaultCid 3

  let depositPath = partyToText requester
  (signEventCid, pendingCid) <- submit (actAs requester <> readAs operator <> readAs sigNetwork) do
    exerciseCmd vaultCid RequestDeposit with
      requester; signerCid; path = depositPath; evmTxParams = sampleEvmParams
      authCid; nonceCidText = "test-nonce"
      keyVersion = 1; algo = "ECDSA"; dest = "ethereum"; params = ""
      outputDeserializationSchema = erc20BoolSchema
      respondSerializationSchema = erc20BoolSchema

  pending <- queryContractId requester pendingCid
  let pd = fromSome pending
  assertMsg "requestId must be 32 bytes" (byteCount pd.requestId == 32)
  assertMsg "evmTxParams must match" (pd.evmTxParams == sampleEvmParams)

  -- SignBidirectionalEvent must exist
  signEvent <- queryContractId requester signEventCid
  assertMsg "sign event must exist" (isSome signEvent)

------------------------------------------------------------------------
-- RequestAuthorization creates proposal
------------------------------------------------------------------------

-- RequestAuthorization creates AuthorizationRequest with correct operators and owner
testRequestAuthorization : Script ()
testRequestAuthorization = do
  (sigNetwork, operator, requester, _signerCid, vaultCid) <- setup

  requestCid <- submit (actAs requester <> readAs operator) do
    exerciseCmd vaultCid RequestAuthorization with requester

  request <- queryContractId operator requestCid
  let p = fromSome request
  assertMsg "request operators" (p.operators == [operator])
  assertMsg "request owner"  (p.owner  == requester)

------------------------------------------------------------------------
-- ApproveAuthorization creates Authorization
------------------------------------------------------------------------

-- ApproveAuthorization creates Authorization with correct operators, owner, and remainingUses
testApproveAuthorization : Script ()
testApproveAuthorization = do
  (sigNetwork, operator, requester, _signerCid, vaultCid) <- setup

  requestCid <- submit (actAs requester <> readAs operator) do
    exerciseCmd vaultCid RequestAuthorization with requester

  authCid <- submit operator do
    exerciseCmd vaultCid ApproveAuthorization with
      requestCid; remainingUses = 5; approver = operator

  auth <- queryContractId operator authCid
  let a = fromSome auth
  assertMsg "auth operators" (a.operators == [operator])
  assertMsg "auth owner"  (a.owner  == requester)
  assertMsg "auth remainingUses" (a.remainingUses == 5)

------------------------------------------------------------------------
-- RequestDeposit validates and decrements auth card
------------------------------------------------------------------------

-- RequestDeposit archives original auth card and creates decremented one (remainingUses 2 → 1)
testRequestDepositBurnsAuthCard : Script ()
testRequestDepositBurnsAuthCard = do
  (sigNetwork, operator, requester, signerCid, vaultCid) <- setup
  authCid <- getAuth operator requester vaultCid 2

  let depositPath = partyToText requester
  _result <- submit (actAs requester <> readAs operator <> readAs sigNetwork) do
    exerciseCmd vaultCid RequestDeposit with
      requester; signerCid; path = depositPath; evmTxParams = sampleEvmParams
      authCid; nonceCidText = "test-nonce"
      keyVersion = 1; algo = "ECDSA"; dest = "ethereum"; params = ""
      outputDeserializationSchema = erc20BoolSchema
      respondSerializationSchema = erc20BoolSchema

  -- Original auth card must be archived
  oldAuth <- queryContractId operator authCid
  assertMsg "original auth card must be archived" (oldAuth == None)

  -- Decremented auth card must exist
  auths <- queryFilter @Authorization operator (\a -> a.owner == requester)
  assertMsg "decremented auth card must exist" (length auths == 1)
  let (_, decremented) = head auths
  assertMsg "decremented remainingUses" (decremented.remainingUses == 1)

------------------------------------------------------------------------
-- Happy-path ClaimDeposit produces Erc20Holding
------------------------------------------------------------------------

-- ClaimDeposit with valid MPC signature creates Erc20Holding and archives all evidence contracts
testClaimHappyPath : Script ()
testClaimHappyPath = do
  (sigNetwork, operator, requester, _signerCid, vaultCid) <- setupWithKey claimTestPubKey

  -- Create evidence contracts directly
  pendingCid <- submit operator do
    createCmd PendingDeposit with
      operators = [operator]; requester; sigNetwork
      requestId = claimTestRequestId; evmTxParams = sampleEvmParams

  respondBidirectionalEventCid <- submit sigNetwork do
    createCmd RespondBidirectionalEvent with
      sigNetwork; operators = [operator]; requester
      requestId = claimTestRequestId
      responder = sigNetwork; serializedOutput = boolTrueMpcOutput
      signature = claimTestSignature

  signatureRespondedEventCid <- submit sigNetwork do
    createCmd SignatureRespondedEvent with
      sigNetwork; operators = [operator]; requester
      requestId = claimTestRequestId
      responder = sigNetwork; signature = claimTestSignature

  holdingCid <- submit (actAs requester <> readAs operator <> readAs sigNetwork) do
    exerciseCmd vaultCid ClaimDeposit with
      requester; pendingDepositCid = pendingCid; respondBidirectionalEventCid; signatureRespondedEventCid

  holding <- queryContractId requester holdingCid
  let h = fromSome holding
  assertMsg "holding owner" (h.owner == requester)
  assertMsg "holding operators" (h.operators == [operator])
  assertMsg "holding erc20Address" (h.erc20Address == sampleEvmParams.to)
  assertMsg "holding amount" (h.amount == "0000000000000000000000000000000000000000000000000000000005f5e100")

  -- Evidence and pending must be archived
  oldPending <- queryContractId requester pendingCid
  assertMsg "pending archived" (oldPending == None)
  oldOutcome <- queryContractId requester respondBidirectionalEventCid
  assertMsg "outcome archived" (oldOutcome == None)
  oldSig <- queryContractId requester signatureRespondedEventCid
  assertMsg "sig archived" (oldSig == None)

------------------------------------------------------------------------
-- ClaimDeposit rejects wrong requester
------------------------------------------------------------------------

-- ClaimDeposit rejects when requester differs from PendingDeposit.requester
testClaimRequesterMismatchFails : Script ()
testClaimRequesterMismatchFails = do
  (sigNetwork, operator, requester, _signerCid, vaultCid) <- setupWithKey claimTestPubKey
  wrongUser <- allocateParty "WrongUser"

  pendingCid <- submit operator do
    createCmd PendingDeposit with
      operators = [operator]; requester; sigNetwork
      requestId = claimTestRequestId; evmTxParams = sampleEvmParams

  respondBidirectionalEventCid <- submit sigNetwork do
    createCmd RespondBidirectionalEvent with
      sigNetwork; operators = [operator]; requester
      requestId = claimTestRequestId
      responder = sigNetwork; serializedOutput = boolTrueMpcOutput
      signature = claimTestSignature

  signatureRespondedEventCid <- submit sigNetwork do
    createCmd SignatureRespondedEvent with
      sigNetwork; operators = [operator]; requester
      requestId = claimTestRequestId
      responder = sigNetwork; signature = claimTestSignature

  submitMustFail (actAs wrongUser <> readAs operator <> readAs sigNetwork) do
    exerciseCmd vaultCid ClaimDeposit with
      requester = wrongUser; pendingDepositCid = pendingCid; respondBidirectionalEventCid; signatureRespondedEventCid

  pure ()

------------------------------------------------------------------------
-- Auth card with 0 remaining uses is rejected (ensure fails)
------------------------------------------------------------------------

-- Authorization with remainingUses=0 is rejected by ensure clause
testAuthCardNoRemainingUsesFails : Script ()
testAuthCardNoRemainingUsesFails = do
  (_sigNetwork, operator, requester, _signerCid, _vaultCid) <- setup

  -- Authorization has ensure remainingUses > 0, so createCmd with 0 must fail
  submitMustFail operator do
    createCmd Authorization with
      operators = [operator]; owner = requester; remainingUses = 0

  pure ()

------------------------------------------------------------------------
-- ClaimDeposit rejects MPC failure (error prefix)
------------------------------------------------------------------------

-- ClaimDeposit rejects when serializedOutput has error prefix (0xDEADBEEF)
testClaimRejectsMpcFailure : Script ()
testClaimRejectsMpcFailure = do
