sampleRecipientAddress : BytesHex
sampleRecipientAddress = "0000000000000000000000001111111111111111111111111111111111111111"

sampleErc20Address : BytesHex
sampleErc20Address = "a0b86991c6218b36c1d19d4a2e9eb0ce3606eb48"

sampleHoldingAmount : BytesHex
