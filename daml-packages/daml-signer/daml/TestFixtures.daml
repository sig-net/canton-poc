sampleVaultAddress : BytesHex
sampleVaultAddress = "000000000000000000000000d8da6bf26964af9d7eed9e03e53415d37aa96045"

sampleEvmParams : EvmTransactionParams
sampleEvmParams = EvmTransactionParams with
  to = "a0b86991c6218b36c1d19d4a2e9eb0ce3606eb48"
  functionSignature = "transfer(address,uint256)"
  encodedArgs = sampleVaultAddress
             <> "0000000000000000000000000000000000000000000000000000000005f5e100"
