# Canton JSON Ledger API
CANTON_JSON_API_URL=http://localhost:7575

# Sepolia RPC endpoint
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# MPC root key pair (secp256k1)
# Private key: 0x-prefixed, 64 hex chars. Only needed by MPC service.
MPC_ROOT_PRIVATE_KEY=0x...
# Public key: uncompressed SEC1 format (04 + x + y), no 0x prefix.
MPC_ROOT_PUBLIC_KEY=04...

# Vault discriminator for MPC key derivation (set at VaultOrchestrator deployment)
VAULT_ID=my-vault

# Faucet key for auto-funding deposit addresses (optional, defaults to MPC_ROOT_PRIVATE_KEY)
# FAUCET_PRIVATE_KEY=0x...

# ERC20 contract address on Sepolia (optional, defaults to 0xB4F1737Af37711e9A5890D9510c9bB60e170CB0D)
# ERC20_ADDRESS=0xB4F1737Af37711e9A5890D9510c9bB60e170CB0D
