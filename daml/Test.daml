      requester = depositor; path = "test"; evmParams = sampleEvmParams
      authCidText = ""; keyVersion = 1; algo = "ECDSA"; dest = "ethereum"
      authCid

------------------------------------------------------------------------
-- Test 29: RequestEvmDeposit rejects wrong functionSignature
------------------------------------------------------------------------

testWrongFunctionSignature : Script ()
testWrongFunctionSignature = do
  issuer    <- allocateParty "Issuer"
  depositor <- allocateParty "Depositor"
  mpc       <- allocateParty "Mpc"

  orchCid <- submit issuer do
    createCmd VaultOrchestrator with
      issuer; mpc; mpcPublicKey = testPubKeyHex; vaultAddress = sampleVaultAddress

  proposalCid <- submit (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid RequestDepositAuth with requester = depositor
  authCid <- submit issuer do
    exerciseCmd orchCid ApproveDepositAuth with proposalCid; remainingUses = 1

  let badParams = sampleEvmParams with functionSignature = "approve(address,uint256)"
  submitMustFail (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid RequestEvmDeposit with
      requester = depositor; path = "test"; evmParams = badParams
      authCidText = ""; keyVersion = 1; algo = "ECDSA"; dest = "ethereum"
      authCid

------------------------------------------------------------------------
-- Test 30: RequestEvmDeposit rejects wrong recipient (not vaultAddress)
------------------------------------------------------------------------

testWrongRecipient : Script ()
testWrongRecipient = do
  issuer    <- allocateParty "Issuer"
  depositor <- allocateParty "Depositor"
  mpc       <- allocateParty "Mpc"

  orchCid <- submit issuer do
    createCmd VaultOrchestrator with
      issuer; mpc; mpcPublicKey = testPubKeyHex; vaultAddress = sampleVaultAddress

  proposalCid <- submit (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid RequestDepositAuth with requester = depositor
  authCid <- submit issuer do
    exerciseCmd orchCid ApproveDepositAuth with proposalCid; remainingUses = 1

  let badParams = sampleEvmParams with
        args = [ "0000000000000000000000001111111111111111111111111111111111111111"
               , "0000000000000000000000000000000000000000000000000000000005f5e100"
               ]
  submitMustFail (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid RequestEvmDeposit with
      requester = depositor; path = "test"; evmParams = badParams
      authCidText = ""; keyVersion = 1; algo = "ECDSA"; dest = "ethereum"
      authCid

------------------------------------------------------------------------
-- Test 31: ClaimEvmDeposit rejects mpcOutput != "01" (ETH failure)
------------------------------------------------------------------------

testClaimRejectsMpcFailure : Script ()
testClaimRejectsMpcFailure = do
  issuer    <- allocateParty "Issuer"
  depositor <- allocateParty "Depositor"
  mpc       <- allocateParty "Mpc"

  orchCid <- submit issuer do
    createCmd VaultOrchestrator with
      issuer; mpc; mpcPublicKey = testPubKeyHex; vaultAddress = sampleVaultAddress

  dummyAuthCid <- submit issuer do
    createCmd DepositAuthorization with
      issuer; mpc; owner = depositor; remainingUses = 0

  pendingCid <- submit issuer do
    createCmd PendingEvmDeposit with
      issuer; requester = depositor; mpc
      requestId = "bb"; path = "test"; evmParams = sampleEvmParams
      authCidText = ""; authCid = dummyAuthCid; keyVersion = 1; algo = "ECDSA"; dest = "ethereum"

  ecdsaCid <- submit issuer do
    createCmd EcdsaSignature with
      issuer; requester = depositor; requestId = "bb"; r = "00"; s = "00"; v = 0

  outcomeCid <- submit issuer do
    createCmd EvmTxOutcomeSignature with
      issuer; requester = depositor; requestId = "bb"
      signature = testSignatureHex; mpcOutput = "00"

  submitMustFail (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid ClaimEvmDeposit with
      requester = depositor; pendingCid; outcomeCid; ecdsaCid

------------------------------------------------------------------------
-- Test 32: ClaimEvmDeposit rejects mismatched requestId
------------------------------------------------------------------------

testClaimRejectsRequestIdMismatch : Script ()
testClaimRejectsRequestIdMismatch = do
  issuer    <- allocateParty "Issuer"
  depositor <- allocateParty "Depositor"
  mpc       <- allocateParty "Mpc"

  orchCid <- submit issuer do
    createCmd VaultOrchestrator with
      issuer; mpc; mpcPublicKey = testPubKeyHex; vaultAddress = sampleVaultAddress

  dummyAuthCid <- submit issuer do
    createCmd DepositAuthorization with
      issuer; mpc; owner = depositor; remainingUses = 0

  pendingCid <- submit issuer do
    createCmd PendingEvmDeposit with
      issuer; requester = depositor; mpc
      requestId = "aa"; path = "test"; evmParams = sampleEvmParams
      authCidText = ""; authCid = dummyAuthCid; keyVersion = 1; algo = "ECDSA"; dest = "ethereum"

  ecdsaCid <- submit issuer do
    createCmd EcdsaSignature with
      issuer; requester = depositor; requestId = "aa"; r = "00"; s = "00"; v = 0

  -- Outcome has different requestId
  outcomeCid <- submit issuer do
    createCmd EvmTxOutcomeSignature with
      issuer; requester = depositor; requestId = "bb"
      signature = testSignatureHex; mpcOutput = "01"

  submitMustFail (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid ClaimEvmDeposit with
      requester = depositor; pendingCid; outcomeCid; ecdsaCid
